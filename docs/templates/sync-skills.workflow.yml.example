name: sync-skills

on:
  workflow_dispatch:
  schedule:
    - cron: "17 3 * * *"
  push:
    paths:
      - "sources.yaml"
      - "scripts/sync-skills.mjs"
      - ".github/workflows/sync-skills.yml"

permissions:
  contents: write
  pull-requests: write

jobs:
  sync:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Setup Node
        uses: actions/setup-node@v4
        with:
          node-version: 22

      - name: Install sync dependencies
        run: npm install --no-save js-yaml

      - name: Sync managed skills
        run: node scripts/sync-skills.mjs

      - name: Validate as skills repo
        run: npx -y skills add . --list

      - name: Create pull request
        uses: peter-evans/create-pull-request@v7
        with:
          commit-message: "chore(skills): sync managed skills"
          title: "chore(skills): sync managed skills"
          body: |
            This PR was generated by the sync-skills workflow.

            It updates externally managed skills declared in `sources.yaml`.
          branch: chore/sync-managed-skills
          delete-branch: true
